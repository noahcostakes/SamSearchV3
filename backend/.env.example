# App
APP_NAME="SAM.gov AI Search (Local)"
DEBUG=true
API_V1_PREFIX="/api/v1"
ENVIRONMENT=local

# Database (local Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/samdb

# Redis (local Docker)
REDIS_URL=redis://localhost:6379

# Security (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your-dev-jwt-secret-min-32-chars-here
ENCRYPTION_MASTER_KEY=your-dev-encryption-key-min-32-chars

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# SAM.gov
SAM_API_BASE_URL=https://api.sam.gov/opportunities/v2/search
SAM_RATE_LIMIT_PER_DAY=950

# CORS (local frontend)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
