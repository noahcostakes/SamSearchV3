# SamSearch Environment Variables
# Copy this file to .env and fill in the values

# =============================================================================
# Application Settings
# =============================================================================
APP_ENV=development
DEBUG=true

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=samsearch
POSTGRES_PASSWORD=samsearch_dev_password
POSTGRES_DB=samsearch
DATABASE_URL=postgresql+asyncpg://samsearch:samsearch_dev_password@localhost:5432/samsearch

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# =============================================================================
# Security Keys (CHANGE THESE IN PRODUCTION!)
# =============================================================================
# JWT Secret Key - Must be at least 32 characters
SECRET_KEY=dev-secret-key-change-in-production-min-32-chars

# Encryption Key for SAM API keys - Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# =============================================================================
# External APIs
# =============================================================================
# Anthropic Claude API Key for AI scoring
ANTHROPIC_API_KEY=

# SAM.gov API Base URL
SAM_API_BASE_URL=https://api.sam.gov/opportunities/v2

# =============================================================================
# CORS Configuration
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# JWT Token Settings
# =============================================================================
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
