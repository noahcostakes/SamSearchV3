# SamSearch Environment Variables
# Copy this file to .env and fill in required values.

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=SAM.gov AI Search
DEBUG=true
ENVIRONMENT=local

# =============================================================================
# Database Configuration
# =============================================================================
POSTGRES_USER=samsearch
POSTGRES_PASSWORD=samsearch_dev_password
POSTGRES_DB=samsearch
DATABASE_URL=postgresql+asyncpg://samsearch:samsearch_dev_password@localhost:5432/samsearch

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Security Keys (CHANGE THESE IN PRODUCTION!)
# =============================================================================
# JWT secret key (>=32 chars)
JWT_SECRET_KEY=dev-secret-key-change-in-production-min-32-chars

# Encryption key for API key storage.
# Preferred: URL-safe base64 string decoding to 32 bytes, for example:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_MASTER_KEY=

# Temporary compatibility option for legacy short/long keys.
ENCRYPTION_ALLOW_LEGACY_FALLBACK=true

# =============================================================================
# AI Configuration
# =============================================================================
USE_LOCAL_AI=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4000

# =============================================================================
# SAM.gov
# =============================================================================
SAM_API_KEY=
SAM_API_BASE_URL=https://api.sam.gov/opportunities/v2/search
SAM_RATE_LIMIT_PER_DAY=950

# =============================================================================
# CORS / Hosts
# =============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1

# =============================================================================
# Celery
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_SEARCHES_PER_DAY=100
RATE_LIMIT_SEARCHES_PER_HOUR=50

# =============================================================================
# Quick Search Output
# =============================================================================
# Number of best matches returned/shown for quick search
QUICK_SEARCH_RESULT_LIMIT=10
# Number of opportunities to score before selecting top matches
AI_SCORING_CANDIDATE_LIMIT=100

# =============================================================================
# Token Settings
# =============================================================================
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# Legacy aliases (optional): APP_ENV, SECRET_KEY, ENCRYPTION_KEY, CORS_ORIGINS
# =============================================================================
